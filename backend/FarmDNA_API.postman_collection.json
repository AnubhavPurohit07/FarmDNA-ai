{
  "info": {
    "name": "FarmDNA API — Week 3",
    "_postman_id": "f4a7d3b0-1234-4abc-9def-farmdna-week3",
    "description": "Collection covering all FarmDNA Decision Journal API endpoints. Base URL assumes the FastAPI server is running locally on port 8000.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/health",
          "host": ["{{base_url}}"],
          "path": ["api", "health"]
        }
      },
      "response": []
    },
    {
      "name": "1. List all entries",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/entries",
          "host": ["{{base_url}}"],
          "path": ["api", "entries"]
        }
      },
      "response": []
    },
    {
      "name": "2. Get single entry by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/entries/1",
          "host": ["{{base_url}}"],
          "path": ["api", "entries", "1"]
        }
      },
      "response": []
    },
    {
      "name": "3. Get entry - not found (404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/entries/999",
          "host": ["{{base_url}}"],
          "path": ["api", "entries", "999"]
        }
      },
      "response": []
    },
    {
      "name": "4. Create new entry",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Tried intercropping with legumes\",\n  \"crop\": \"Maize\",\n  \"region\": \"Uttar Pradesh\",\n  \"season\": \"Kharif 2026\",\n  \"decision\": \"Planted cowpea between maize rows\",\n  \"reason\": \"Wanted to improve soil nitrogen naturally\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/entries",
          "host": ["{{base_url}}"],
          "path": ["api", "entries"]
        }
      },
      "response": []
    },
    {
      "name": "5. Create entry - validation error (400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"a\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/entries",
          "host": ["{{base_url}}"],
          "path": ["api", "entries"]
        }
      },
      "response": []
    },
    {
      "name": "6. Update an entry",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"success\",\n  \"outcome\": \"Soil nitrogen improved, maize yield up slightly.\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/entries/1",
          "host": ["{{base_url}}"],
          "path": ["api", "entries", "1"]
        }
      },
      "response": []
    },
    {
      "name": "7. Search entries by keyword",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/entries/search?q=wheat",
          "host": ["{{base_url}}"],
          "path": ["api", "entries", "search"],
          "query": [
            { "key": "q", "value": "wheat" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "8. Delete an entry",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/entries/2",
          "host": ["{{base_url}}"],
          "path": ["api", "entries", "2"]
        }
      },
      "response": []
    },
    {
      "name": "9. Delete entry - not found (404)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/entries/999",
          "host": ["{{base_url}}"],
          "path": ["api", "entries", "999"]
        }
      },
      "response": []
    }
  ]
}
