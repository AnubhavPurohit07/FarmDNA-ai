PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# MongoDB Atlas connection string.
# Get this from Atlas: Database -> Connect -> Drivers -> Python
# Replace <username> and <password> with your actual database user credentials.
MONGO_URI=mongodb+srv://<username>:<password>@your-cluster.mongodb.net/?retryWrites=true&w=majority

# Name of the database to use within your cluster (created automatically on first write)
DB_NAME=farmdna
